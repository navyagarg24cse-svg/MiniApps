<?xml version="1.0" encoding="utf-8"?>
<!--
    AndroidManifest.xml
    ───────────────────
    Key additions vs a default manifest:
      1. CAMERA permission
      2. READ/WRITE storage permissions (with maxSdkVersion guards)
      3. READ_MEDIA_IMAGES for Android 13+
      4. FileProvider <provider> block
-->
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.example.galleryapp">

    <!-- ── Permissions ─────────────────────────────────────────── -->

    <!-- Camera -->
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-feature android:name="android.hardware.camera" android:required="false" />

    <!-- Storage — WRITE only needed below Android 10 -->
    <uses-permission
        android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="28" />

    <!-- READ_EXTERNAL_STORAGE — needed on API 29–32 to query MediaStore -->
    <uses-permission
        android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />

    <!-- Android 13+ (API 33) replaced READ_EXTERNAL_STORAGE with granular permissions -->
    <uses-permission android:name="android.permission.READ_MEDIA_IMAGES" />

    <!-- Fixes "consider adding <queries>" warning — declares camera intent usage -->
    <queries>
        <intent>
            <action android:name="android.media.action.IMAGE_CAPTURE" />
        </intent>
    </queries>

    <!-- ── Application ─────────────────────────────────────────── -->
    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.GalleryApp">

        <!-- Main / Home Screen -->
        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Gallery Screen -->
        <activity android:name=".GalleryActivity"
            android:exported="false" />

        <!-- Detail Screen -->
        <activity android:name=".DetailActivity"
            android:exported="false" />

        <!-- ── FileProvider ────────────────────────────────────── -->
        <!--
            REQUIRED for sharing file:// URIs with the camera app on Android 7+.
            authority MUST match the string used in FileProvider.getUriForFile():
                getPackageName() + ".fileprovider"
            For package "com.example.galleryapp" → "com.example.galleryapp.fileprovider"
        -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

    </application>

</manifest>